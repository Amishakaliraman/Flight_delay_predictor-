   "source": [
    "import pandas as pd\n",
    "import sqlite3\n",
    "\n",
    "#load csv file \n",
    "df= pd.read_csv(\"../Data/flights_dataset.csv\")\n",
    "\n",
    "#connect to database\n",
    "conn= sqlite3.connect(\"../Data/flights.db\")\n",
    "\n",
    "# write to sqlite\n",
    "df.to_sql(\"flights\",conn, if_exists='replace', index=False)\n",
    "\n",
    "conn.close()"
   ]
